<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} - Hammerspoon 2 API</title>
    <link rel="stylesheet" href="styles.css">
    <script src="highlight.min.js"></script>
</head>
<body>
    <!-- Top header bar -->
    <header class="top-header">
        <div class="header-left">
            <a href="index.html" class="site-logo">Hammerspoon 2</a>
            <span class="version-badge">API Docs</span>
        </div>
        <div class="header-center">
            <div class="search-wrapper">
                <svg class="search-icon" viewBox="0 0 16 16" width="16" height="16" aria-hidden="true">
                    <path fill-rule="evenodd" d="M11.5 7a4.499 4.499 0 11-8.998 0A4.499 4.499 0 0111.5 7zm-.82 4.74a6 6 0 111.06-1.06l3.04 3.04a.75.75 0 11-1.06 1.06L10.68 11.74z"></path>
                </svg>
                <input type="search" id="search-input" class="search-input" placeholder="Search properties and methods…" aria-label="Search">
            <div id="search-results" class="search-results" hidden></div>
            </div>
        </div>
        <div class="header-right">
            <a href="https://github.com/cmsj/Hammerspoon2" class="github-link" target="_blank" rel="noopener noreferrer" aria-label="GitHub repository">
                <svg viewBox="0 0 16 16" width="20" height="20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"></path>
                </svg>
            </a>
        </div>
    </header>

    <div class="layout-body">
        <!-- Left sidebar -->
        <nav class="sidebar-left" aria-label="Site navigation">
            <div class="nav-section" id="modules-section">
                <div class="nav-section-label">MODULES</div>
                <div id="modules-nav"></div>
            </div>
            <div class="nav-section" id="types-section">
                <div class="nav-section-label">TYPES</div>
                <div id="types-nav"></div>
            </div>
        </nav>

        <!-- Main content -->
        <main class="content" id="main-content">
            {% block breadcrumb %}{% endblock %}
            {% block content %}{% endblock %}
        </main>

        <!-- Right TOC sidebar -->
        <aside class="toc-sidebar" aria-label="On this page">
            <div class="toc-label">ON THIS PAGE</div>
            <nav id="toc-nav"></nav>
        </aside>
    </div>

    <script src="script.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            loadNavigation('{{ currentPage }}');
            generateTOC();
            addCopyButtons();
            initSearch();
            initTOCObserver();
        });
    </script>
</body>
</html>
