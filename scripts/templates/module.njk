{% extends "base.njk" %}

{% block breadcrumb %}
<nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="index.html">API Reference</a>
    <span class="breadcrumb-sep">›</span>
    <span class="breadcrumb-current">{{ module.name }}</span>
</nav>
{% endblock %}

{% block content %}
<div class="page-header">
    <h1>{{ module.name }}</h1>
    <span class="page-badge">Module</span>
</div>

{% if module.rawDocumentation %}
<div class="module-description">{{ module.rawDocumentation | markdown | safe }}</div>
{% endif %}

{% if typeDefinitions.length > 0 %}
<h2 class="section-heading">Types</h2>
<p style="color: var(--text-secondary); font-size: 0.9375rem; margin-bottom: 0.75rem;">This module provides the following types:</p>
<ul class="type-list">
{% for typeDef in typeDefinitions %}
    <li>
        <a href="{{ typeDef.name | replace('API', '') }}.html">{{ typeDef.name | replace('API', '') }}</a>
    </li>
{% endfor %}
</ul>
{% endif %}

<h2 class="section-heading">Properties</h2>
{% if module.properties and module.properties.length > 0 %}
    {% for prop in module.properties %}
    <div class="property" id="{{ prop.name }}">
        <h3><a href="#{{ prop.name }}">{{ module.name }}.{{ prop.name }}</a></h3>
        <div class="prop-type">{{ prop.signature | extractPropertyType | formatType }}</div>
        <div class="description">{{ prop.description }}</div>
        {% if prop | githubSourceUrl %}
        <div class="source-link">
            <a href="{{ prop | githubSourceUrl }}" target="_blank" rel="noopener noreferrer">{{ prop.filePath }}:{{ prop.lineNumber }}</a>
        </div>
        {% endif %}
    </div>
    {% endfor %}
{% else %}
<p style="color: var(--text-secondary); font-size: 0.9375rem; margin-bottom: 1.5rem;">This module has no properties.</p>
{% endif %}

<h2 class="section-heading">Methods</h2>
{% if methods.length > 0 %}
    {% for method in methods %}
    <div class="method" id="{{ method.name }}">
        <h3><a href="#{{ method.name }}">{{ module.name }}.{{ method.name }}({% for param in method.params %}{{ param.name }}{% if not loop.last %}, {% endif %}{% endfor %}) -> {% if method.returns %}{{ method.returns | formatReturnType | safe }}{% else %}None{% endif %}</a></h3>

        <div class="description">{{ method.description }}</div>

        <div class="card-section-label">Declaration</div>
        <pre><code class="language-javascript">{{ module.name }}.{{ method.name }}({% for param in method.params %}{{ param.name }}{% if not loop.last %}, {% endif %}{% endfor %}) -> {% if method.returns %}{{ method.returns | formatReturnType | safe }}{% else %}None{% endif %}</code></pre>

        {% if method.params.length > 0 %}
        <div class="card-section-label">Parameters</div>
        <table class="params-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Type</th>
                    <th>Description</th>
                </tr>
            </thead>
            <tbody>
                {% for param in method.params %}
                <tr>
                    <td class="param-name">{{ param.name }}</td>
                    <td class="param-type">{{ param | resolveParamType }}</td>
                    <td class="param-desc">{{ param.description }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% endif %}

        <div class="card-section-label">Returns</div>
        {% if method.returns %}
        <div class="return-type">{{ method.returns | formatReturnType | safe }}</div>
        <div class="return-desc">{{ method.returns.description }}</div>
        {% else %}
        <div class="return-desc" style="color: var(--text-muted);">None</div>
        {% endif %}

        {% if method.examples and method.examples.length > 0 %}
        <div class="card-section-label">Example</div>
        {% for example in method.examples %}
        <pre><code class="language-{{ example.lang }}">{{ example.code }}</code></pre>
        {% endfor %}
        {% endif %}

        {% if method | githubSourceUrl %}
        <div class="source-link">
            <a href="{{ method | githubSourceUrl }}" target="_blank" rel="noopener noreferrer">{{ method.filePath }}:{{ method.lineNumber }}</a>
        </div>
        {% endif %}
    </div>
    {% endfor %}
{% else %}
<p style="color: var(--text-secondary); font-size: 0.9375rem;">This module has no methods.</p>
{% endif %}
{% endblock %}
